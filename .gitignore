# Rust build artifacts (Cargo.lock IS committed)
/target/

# turbovec / fastembed downloaded model cache (from the turbovec feature's tests)
/.fastembed_cache/

# Local event store / graph / scratch (runtime state; .rigger/workflow.yml IS committed)
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3
.rigger/cache/
# Persisted turbovec grounding index (embeddings + the id->Ref map): per-machine
# derived data rebuilt from the tree, large + binary, never committed.
.rigger/grounding/
# The `rigger step` serialization lock (fs2 flock target): runtime-only, per-machine.
.rigger/step.lock
# Persisted symbol index (spec 15): a rebuildable projection of the tree, per-machine
# derived data, never committed.
.rigger/symbols/
# Distilled playbook pool (spec 13, unit 7): a rebuildable projection of the log
# (`rigger playbooks --rebuild`), derived per-machine, never hand-edited state.
.rigger/playbooks/

# Node deps for the workflow shim (shim/package-lock.json IS committed)
shim/node_modules/

# Editor / OS
.DS_Store
.idea/
.vscode/
.claude
.rigger/shim
# The run's transient scratch root: unit/review worktrees + their build dirs
# (defaults.workdir / RIGGER_TMPDIR override the location; Gap 14)
.rigger/tmp
